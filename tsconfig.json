{
  "compileOnSave": false,
  "compilerOptions": {
    "baseUrl": "./",
    "moduleResolution": "bundler",
    "allowJs": true,
    "emitDecoratorMetadata": false,
    "experimentalDecorators": true,
    "esModuleInterop": true,
    "skipLibCheck": false,
    "declaration": false,
    "sourceMap": true,
    "importHelpers": true,
    "target": "ES2022",
    "module": "es2020",
    "typeRoots": ["node_modules/@types"],
    "paths": {
      "@videogular/ngx-videogular": ["libs/ngx-videogular/public-api"],
      "@videogular/ngx-videogular/*": ["libs/ngx-videogular/*/src/index"]
    },
    "useDefineForClassFields": false
  },
  "include": ["commitlint.config.js", ".eslintrc.js"],
  "exclude": ["node_modules", "tmp"]
}
